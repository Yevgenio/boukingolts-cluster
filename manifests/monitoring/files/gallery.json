{
  "title": "Gallery Overview",
  "uid": "gallery-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": {},
  "panels": [
    {
      "id": 1,
      "title": "Requests / sec",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 16, "h": 8 },
      "targets": [
        {
          "expr": "sum by (route) (rate(http_requests_total{job=\"gallery-backend\"}[5m]))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 2,
      "title": "Error rate (5xx)",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"gallery-backend\", status=~\"5..\"}[5m])) or vector(0)",
          "legendFormat": "errors/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.01 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 3,
      "title": "Backend memory (MB)",
      "type": "stat",
      "gridPos": { "x": 16, "y": 4, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "backend_process_resident_memory_bytes / 1024 / 1024",
          "legendFormat": "RSS MB",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 300 },
              { "color": "red", "value": 450 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 4,
      "title": "Response time p95 (ms)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (route, le) (rate(http_request_duration_seconds_bucket{job=\"gallery-backend\"}[5m]))) * 1000",
          "legendFormat": "p95 {{route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        }
      }
    },
    {
      "id": 5,
      "title": "4xx client errors / sec",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 8, "h": 7 },
      "targets": [
        {
          "expr": "sum by (route) (rate(http_requests_total{job=\"gallery-backend\", status=~\"4..\"}[5m]))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "fixedColor": "orange", "mode": "fixed" }
        }
      }
    },
    {
      "id": 6,
      "title": "Top product views — selected period",
      "description": "Change the time range (top right) to see daily / weekly / monthly views.",
      "type": "barchart",
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 9 },
      "targets": [
        {
          "expr": "topk(10, increase(gallery_product_views_total[${__range_s}s]))",
          "legendFormat": "{{product_name}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 80 }
        }
      },
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0,
        "legend": { "displayMode": "hidden" }
      }
    },
    {
      "id": 7,
      "title": "Top event views — selected period",
      "description": "Change the time range (top right) to see daily / weekly / monthly views.",
      "type": "barchart",
      "gridPos": { "x": 12, "y": 15, "w": 8, "h": 9 },
      "targets": [
        {
          "expr": "topk(5, increase(gallery_event_views_total[${__range_s}s]))",
          "legendFormat": "{{event_name}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 80 }
        }
      },
      "options": {
        "orientation": "horizontal",
        "legend": { "displayMode": "hidden" }
      }
    },
    {
      "id": 8,
      "title": "Total requests — selected period",
      "type": "stat",
      "gridPos": { "x": 0, "y": 24, "w": 5, "h": 4 },
      "targets": [
        {
          "expr": "sum(increase(http_requests_total{job=\"gallery-backend\"}[${__range_s}s]))",
          "legendFormat": "",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 } },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "none", "graphMode": "none" }
    },
    {
      "id": 9,
      "title": "Total product views — selected period",
      "type": "stat",
      "gridPos": { "x": 5, "y": 24, "w": 5, "h": 4 },
      "targets": [
        {
          "expr": "sum(increase(gallery_product_views_total[${__range_s}s]))",
          "legendFormat": "",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "none", "graphMode": "none" }
    },
    {
      "id": 10,
      "title": "Total event views — selected period",
      "type": "stat",
      "gridPos": { "x": 10, "y": 24, "w": 5, "h": 4 },
      "targets": [
        {
          "expr": "sum(increase(gallery_event_views_total[${__range_s}s]))",
          "legendFormat": "",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "none", "graphMode": "none" }
    }
  ]
}
